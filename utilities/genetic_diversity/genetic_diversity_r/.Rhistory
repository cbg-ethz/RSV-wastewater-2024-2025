"covered_genome",
"covered_F",
"covered_G",
"genome_location"
)]
rsvb_diversity_matrix$Date <- as.Date(rsvb_diversity_matrix$date,format = "%Y_%m_%d")
rsvb_diversity_matrix <- rsvb_diversity_matrix %>%
select(-date) %>%
mutate(subtype = "B")
# merge genetic diversity dataframes
rsv_div_matrix <- rbind(rsva_diversity_matrix, rsvb_diversity_matrix)
View(rsv_div_matrix)
model <- lmer(shannon_entropy ~ date_centered + (1 | genome_location)+(1 | subtype),
data = rsva_diversity_matrix)
model <- lmer(shannon_entropy ~ Date + (1 | genome_location)+(1 | subtype),
data = rsva_diversity_matrix)
